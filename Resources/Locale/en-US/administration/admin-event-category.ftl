admin-event-category-none = None

admin-event-category-T1-title = T1
admin-event-category-T1-description = Minor events. Any intervention from admins that doesn't disrupt the round flow in any meaningful way. These events hardly change anything other than some small flavor.

admin-event-category-T2-title = T2
admin-event-category-T2-description = Medium events. Any intervention that disrupts the round-flow but in minor form. These events do impact the round, however in a minor way that maybe only a few players will be affected.

admin-event-category-T3-title = T3
admin-event-category-T3-description = Major events. These include major intervention that disrupt the round flow in major form. These events have a big impact on the round. perhaps only some players won't be affected.

admin-event-category-T4-title = T4
admin-event-category-T4-description = Mega events. These are stuff that dramatically change the round flow to something completely different.
